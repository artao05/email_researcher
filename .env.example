# Sponsorship Email Assistant — shared secrets (used by weft-server/)
# Fill in your keys below, then run: bash scripts/start-weft.sh

DEPLOYMENT_MODE=local
# Do NOT set INFRASTRUCTURE_TARGET=local unless you installed kind/K8s
WEFT_API_PORT=3000

# Required for research
TAVILY_API_KEY=

# At least one LLM provider (UI can also supply keys)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional — Google Sheet write-back (paste full service account JSON on one line)
# GOOGLE_SERVICE_ACCOUNT_JSON=
