# Project: Sponsorship Email Assistant
# Description: Research a company, human review, draft sponsorship email

# ── Entry point ──────────────────────────────────────────────
trigger = ApiPost -> (
  companies: String,
  event_description: String,
  sheet_id: String,
  template: String,
  llm_provider: String,
  llm_model: String,
  api_keys: String,
  google_credentials: String
) {
  label: "Research Trigger"
}

llm_config = LlmConfig {
  label: "Research LLM (fallback via OpenRouter)"
  model: "gpt-4o-mini"
  temperature: "0.3"
  maxTokens: "4096"
  systemPrompt: "You are a sponsorship research assistant. Return ONLY valid JSON matching the requested schema. Never return email templates or markdown code fences."
}

# Shared ExecPython LLM router — supports OpenAI, OpenRouter, Gemini, Groq
tavily_config = TavilyConfig {
  label: "Tavily Config"
}

# ── Parse first company from JSON list (UI sends all companies) ─
parse_company = ExecPython(
  companies: String,
  event_description: String,
  sheet_id: String,
  template: String
) -> (
  company_name: String,
  company_row: String,
  event_description: String,
  sheet_id: String,
  template: String
) {
  label: "Parse Company"
  code: ```
import json
arr = json.loads(companies or "[]")
c = arr[0] if arr else {}
return {
  "company_name": c.get("name", "Unknown"),
  "company_row": str(c.get("row", 2)),
  "event_description": event_description,
  "sheet_id": sheet_id,
  "template": template,
}
```
}
parse_company.companies = trigger.companies
parse_company.event_description = trigger.event_description
parse_company.sheet_id = trigger.sheet_id
parse_company.template = trigger.template

# ── Research ─────────────────────────────────────────────────
news_query = Template {
  label: "News Query"
  template: "{{company_name}} company news sponsorship partnership 2025 2026"
}
news_query.company_name = parse_company.company_name

mission_query = Template {
  label: "Mission Query"
  template: "{{company_name}} mission sleep circadian health about"
}
mission_query.company_name = parse_company.company_name

news_search = TavilySearch {
  label: "News Search"
}
news_search.config = tavily_config.config
news_search.query = news_query.text

mission_search = TavilySearch {
  label: "Mission Search"
}
mission_search.config = tavily_config.config
mission_search.query = mission_query.text

synth_prompt = Template {
  label: "Synthesis Prompt"
  template: "Analyze sponsorship fit for {{company_name}} and this event: {{event_description}}.\n\nNews research:\n{{news}}\n\nMission/company research:\n{{mission}}\n\nReturn ONLY a JSON object (no markdown fences) with this exact shape:\n{\"discovered_url\":\"company website if found\",\"brief\":\"2-3 paragraph research summary about the company and why they might sponsor\",\"scores\":{\"mission\":{\"score\":0,\"justification\":\"\"},\"recent_activity\":{\"score\":0,\"justification\":\"\"},\"audience\":{\"score\":0,\"justification\":\"\"},\"overall\":{\"score\":0,\"justification\":\"\"}},\"personalization_plan\":\"bullet list of email angles\",\"research_highlights\":[\"\"]}\n\nDo NOT return email templates. Scores must be integers 1-10."
}
synth_prompt.company_name = parse_company.company_name
synth_prompt.event_description = parse_company.event_description
synth_prompt.news = news_search.answer
synth_prompt.mission = mission_search.answer

synthesizer = ExecPython(
  prompt: String,
  llm_provider: String,
  llm_model: String,
  api_keys: String
) -> (response: String) {
  label: "Research Synthesizer"
  code: ```
import json, urllib.request, os

SYSTEM = "You are a sponsorship research assistant. Return ONLY valid JSON matching the requested schema. Never return email templates or markdown code fences."
ENV_KEYS = {"openai": "OPENAI_API_KEY", "openrouter": "OPENROUTER_API_KEY", "gemini": "GEMINI_API_KEY", "groq": "GROQ_API_KEY"}
DEFAULT_MODELS = {"openai": "gpt-4o-mini", "openrouter": "google/gemini-2.5-flash", "gemini": "gemini-2.0-flash", "groq": "llama-3.3-70b-versatile"}

def pick_key(provider, keys_json):
    keys = json.loads(keys_json or "{}")
    order = [provider, "openai", "openrouter", "gemini", "groq"]
    seen = set()
    for p in order:
        if p in seen:
            continue
        seen.add(p)
        k = keys.get(p) or os.environ.get(ENV_KEYS.get(p, ""), "")
        if k:
            return p, k
    raise RuntimeError("No LLM API key available")

def chat_openai(model, key, prompt):
    req = urllib.request.Request("https://api.openai.com/v1/chat/completions", data=json.dumps({
        "model": model, "messages": [{"role": "system", "content": SYSTEM}, {"role": "user", "content": prompt}],
        "temperature": 0.3, "max_tokens": 4096,
    }).encode(), headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]

def chat_openrouter(model, key, prompt):
    req = urllib.request.Request("https://openrouter.ai/api/v1/chat/completions", data=json.dumps({
        "model": model, "messages": [{"role": "system", "content": SYSTEM}, {"role": "user", "content": prompt}],
        "temperature": 0.3, "max_tokens": 4096,
    }).encode(), headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]

def chat_gemini(model, key, prompt):
    url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={key}"
    req = urllib.request.Request(url, data=json.dumps({"contents": [{"parts": [{"text": SYSTEM + "\\n\\n" + prompt}]}]}).encode(), headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["candidates"][0]["content"]["parts"][0]["text"]

def chat_groq(model, key, prompt):
    req = urllib.request.Request("https://api.groq.com/openai/v1/chat/completions", data=json.dumps({
        "model": model, "messages": [{"role": "system", "content": SYSTEM}, {"role": "user", "content": prompt}],
        "temperature": 0.3, "max_tokens": 4096,
    }).encode(), headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]

CALLERS = {"openai": chat_openai, "openrouter": chat_openrouter, "gemini": chat_gemini, "groq": chat_groq}
p, key = pick_key(llm_provider, api_keys)
model = llm_model or DEFAULT_MODELS.get(p, "gpt-4o-mini")
return {"response": CALLERS[p](model, key, prompt)}
```
}
synthesizer.prompt = synth_prompt.text
synthesizer.llm_provider = trigger.llm_provider
synthesizer.llm_model = trigger.llm_model
synthesizer.api_keys = trigger.api_keys

parse_synth = ExecPython(response: String, company_name: String) -> (
  company_name: String,
  discovered_url: String,
  brief: String,
  scores: String,
  process: String
) {
  label: "Parse Synthesis"
  code: ```
import json, re

def parse_json(text):
    text = (text or "").strip()
    if not text:
        return {}
    try:
        return json.loads(text)
    except Exception:
        pass
    m = re.search(r"```(?:json)?\s*([\s\S]*?)```", text)
    if m:
        try:
            return json.loads(m.group(1).strip())
        except Exception:
            pass
    m = re.search(r"\{[\s\S]*\}", text)
    if m:
        try:
            return json.loads(m.group(0))
        except Exception:
            pass
    return {"brief": text, "scores": {}, "personalization_plan": ""}

data = parse_json(response)
brief = data.get("brief", "")
if not brief and data.get("blocks"):
    brief = "Research synthesis failed — the model returned an email template instead of research. Skip and re-run, or request a deeper dive."
scores = data.get("scores") or {}
if not isinstance(scores, dict):
    scores = {}
process = data.get("personalization_plan", data.get("process", ""))
if isinstance(process, list):
    process = "\n".join(f"- {item}" for item in process if item)
elif isinstance(process, dict):
    process = json.dumps(process)
else:
    process = str(process or "")
return {
    "company_name": company_name,
    "discovered_url": data.get("discovered_url", ""),
    "brief": brief,
    "scores": json.dumps(scores),
    "process": process,
}
```
}
parse_synth.response = synthesizer.response
parse_synth.company_name = parse_company.company_name

# ── Human review ─────────────────────────────────────────────
review = HumanQuery {
  label: "Review Research"
  title: "Sponsorship Email Review"
  fields: [
    {"fieldType": "display", "key": "company_name"},
    {"fieldType": "display", "key": "discovered_url"},
    {"fieldType": "display", "key": "brief"},
    {"fieldType": "display", "key": "scores"},
    {"fieldType": "display", "key": "process"},
    {"fieldType": "approve_reject", "key": "decision", "config": {
      "approveLabel": "Approve & Write to Sheet",
      "rejectLabel": "Request Deeper Dive"
    }},
    {"fieldType": "textarea", "key": "annotation"},
    {"fieldType": "text_input", "key": "deeper_dive_direction"}
  ]
}
review.company_name = parse_synth.company_name
review.discovered_url = parse_synth.discovered_url
review.brief = parse_synth.brief
review.scores = parse_synth.scores
review.process = parse_synth.process

# ── Routing ──────────────────────────────────────────────────
approve_gate = Gate { label: "If Approved" }
approve_gate.pass = review.decision_approved
approve_gate.value = review.annotation

dive_gate = Gate { label: "If Deeper Dive" }
dive_gate.pass = review.decision_rejected
dive_gate.value = review.deeper_dive_direction

deep_query = Template {
  label: "Deep Dive Query"
  template: "{{company_name}} {{direction}}"
}
deep_query.company_name = parse_company.company_name
deep_query.direction = dive_gate.value

deep_search = TavilySearch {
  label: "Deep Dive Search"
}
deep_search.config = tavily_config.config
deep_search.query = deep_query.text

# ── Draft email on approve ───────────────────────────────────
draft_prompt = Template {
  label: "Draft Email Prompt"
  template: "Write a sponsorship email for {{company_name}}. Event: {{event_description}}. Template JSON: {{template}}. Research brief: {{brief}}. User notes: {{annotation}}. Rules: keep fixed blocks verbatim, personalize variable blocks using research. Return ONLY JSON: {\"subject\":\"...\",\"body\":\"full email\"}"
}
draft_prompt.company_name = parse_company.company_name
draft_prompt.event_description = parse_company.event_description
draft_prompt.template = parse_company.template
draft_prompt.brief = parse_synth.brief
draft_prompt.annotation = approve_gate.value

outreach_llm = ExecPython(
  prompt: String,
  llm_provider: String,
  llm_model: String,
  api_keys: String
) -> (response: String) {
  label: "Email Drafter"
  code: ```
import json, urllib.request, os

SYSTEM = "You write sponsorship outreach emails. Return ONLY valid JSON with subject and body fields."
ENV_KEYS = {"openai": "OPENAI_API_KEY", "openrouter": "OPENROUTER_API_KEY", "gemini": "GEMINI_API_KEY", "groq": "GROQ_API_KEY"}
DEFAULT_MODELS = {"openai": "gpt-4o-mini", "openrouter": "google/gemini-2.5-flash", "gemini": "gemini-2.0-flash", "groq": "llama-3.3-70b-versatile"}

def pick_key(provider, keys_json):
    keys = json.loads(keys_json or "{}")
    order = [provider, "openai", "openrouter", "gemini", "groq"]
    seen = set()
    for p in order:
        if p in seen:
            continue
        seen.add(p)
        k = keys.get(p) or os.environ.get(ENV_KEYS.get(p, ""), "")
        if k:
            return p, k
    raise RuntimeError("No LLM API key available")

def chat_openai(model, key, prompt):
    req = urllib.request.Request("https://api.openai.com/v1/chat/completions", data=json.dumps({
        "model": model, "messages": [{"role": "system", "content": SYSTEM}, {"role": "user", "content": prompt}],
        "temperature": 0.3, "max_tokens": 4096,
    }).encode(), headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]

def chat_openrouter(model, key, prompt):
    req = urllib.request.Request("https://openrouter.ai/api/v1/chat/completions", data=json.dumps({
        "model": model, "messages": [{"role": "system", "content": SYSTEM}, {"role": "user", "content": prompt}],
        "temperature": 0.3, "max_tokens": 4096,
    }).encode(), headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]

def chat_gemini(model, key, prompt):
    url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={key}"
    req = urllib.request.Request(url, data=json.dumps({"contents": [{"parts": [{"text": SYSTEM + "\\n\\n" + prompt}]}]}).encode(), headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["candidates"][0]["content"]["parts"][0]["text"]

def chat_groq(model, key, prompt):
    req = urllib.request.Request("https://api.groq.com/openai/v1/chat/completions", data=json.dumps({
        "model": model, "messages": [{"role": "system", "content": SYSTEM}, {"role": "user", "content": prompt}],
        "temperature": 0.3, "max_tokens": 4096,
    }).encode(), headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json"})
    with urllib.request.urlopen(req, timeout=120) as r:
        return json.loads(r.read())["choices"][0]["message"]["content"]

CALLERS = {"openai": chat_openai, "openrouter": chat_openrouter, "gemini": chat_gemini, "groq": chat_groq}
p, key = pick_key(llm_provider, api_keys)
model = llm_model or DEFAULT_MODELS.get(p, "gpt-4o-mini")
return {"response": CALLERS[p](model, key, prompt)}
```
}
outreach_llm.prompt = draft_prompt.text
outreach_llm.llm_provider = trigger.llm_provider
outreach_llm.llm_model = trigger.llm_model
outreach_llm.api_keys = trigger.api_keys

output_debug = Debug { label: "Final Output" }
output_debug.data = outreach_llm.response
